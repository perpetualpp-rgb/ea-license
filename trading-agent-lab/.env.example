# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).

# --- AI agents (optional) ---------------------------------------------------
# Real Hermes / OpenAI-compatible decisions. Unset -> agents use indicator rules.
NOUS_API_KEY=

# --- Live exchange keys (optional, ONLY for live trading) -------------------
# Required only when broker.mode=live AND dry_run=false. Use TESTNET keys first.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# --- Live arming switch -----------------------------------------------------
# Must be "1" to even *arm* live trading (equivalent to passing --live). Even
# then, real orders need broker.mode=live + dry_run=false + the keys above.
# Leave unset/0 to stay paper. START WITH TESTNET. You trade at your own risk.
ALLOW_LIVE=0
